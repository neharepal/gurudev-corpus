# ===== OS / editor =====
.DS_Store
*.swp
*~

# ===== Secrets / env =====
.env
.env.*
# Lightsail/AWS SSH keys — never commit even by accident.
lightsail/
# Ad-hoc pipeline snapshots (chunker/parents/text.md backups) — MB-to-GB
# scale; recreate from the current source-of-truth files if needed. The
# broader `*.bak` rule catches text.md rollback anchors we drop next to a
# canonical file before an in-place OCR-quality swap.
04_processed/*.bak
*.bak
# But do commit the deploy config template — it's the only safe way for a
# fresh clone (Lightsail, ECS, whatever) to know which env vars matter.
!deploy/.env.example
*.pem
*.key
secrets.*

# ===== Node / Next.js (chat-app) =====
node_modules/
.next/
out/
build/
coverage/
*.tsbuildinfo
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== Python =====
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# ===== Source documents / scans / archives (too large for git) =====
*.pdf
*.docx
*.doc
*.pub
*.zip
*.gz
*.tar
*.7z
*.rar

