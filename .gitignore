# ===== OS / editor =====
.DS_Store
*.swp
*~

# ===== Secrets / env =====
.env
.env.*
# But do commit the deploy config template — it's the only safe way for a
# fresh clone (Lightsail, ECS, whatever) to know which env vars matter.
!deploy/.env.example
*.pem
*.key
secrets.*

# ===== Node / Next.js (chat-app) =====
node_modules/
.next/
out/
build/
coverage/
*.tsbuildinfo
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== Python =====
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

