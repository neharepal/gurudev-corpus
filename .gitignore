!chat-app/public/*.jpg
!chat-app/public/*.jpeg
!chat-app/public/*.png

# ===== Processed ML artifacts / bulk data =====
*.npy
*.npz
*.bin
*.pt
*.jsonl

# ===== Bulk data directories (raw dumps, embeddings, photos) =====
00_raw/
photos/
04_processed/embeddings/
04_processed/ia_cache/

# ===== Local Claude Code settings =====
.claude/
.superpowers/

# Surya OCR venv (py3.12, large)
.venv-surya/

# Surya OCR handoff kit (source PDFs, large)
# Ignore _surya_ocr_job/ contents (venv/, pdfs/, out/, out_raw/, log files)
# BUT keep the pipeline scripts trackable — otherwise fixes to run_ocr.sh
# (like the 2026-07-19 PATH patch for llama-server) don't survive machine
# transfers. Use `*` not `/` on the top rule so git descends into the folder
# and can evaluate the negations below.
_surya_ocr_job/*
!_surya_ocr_job/run_ocr.sh
!_surya_ocr_job/assemble.py
!_surya_ocr_job/HANDOVER.md

# Surya re-OCR generated decisions (transient)
tools/surya_ocr/replace_decisions.yaml

# runtime logs
logs/

# transient backups
04_processed/_bak-*/

# M4 migration transfer bundle
_m4_transfer/
