# Deploy secrets + config for the Lightsail (or any Docker) host.
# Copy to `.env` in this directory and fill in real values.
#
#   cp deploy/.env.example deploy/.env
#   $EDITOR deploy/.env
#
# `.env` is gitignored — never commit real values.

# --- Anthropic API key (ADR-003) -------------------------------------------
# https://console.anthropic.com/settings/keys — keep out of chat logs.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Public domain served over HTTPS ---------------------------------------
# The subdomain that points at this Lightsail box's static IP. Caddy will
# request a Let's Encrypt cert for exactly this host.
DOMAIN=api.example.com
LETSENCRYPT_EMAIL=you@example.com

# --- Frontend origin lock (CORS) -------------------------------------------
# The Vercel deployment's public URL. FastAPI CORS allows ONLY this origin.
# Multiple origins may be comma-separated (e.g. preview + prod deployments).
FRONTEND_ORIGIN=https://gurudev-sangrah.vercel.app

# --- Invite gate (RFC-016 §3 light gate) -----------------------------------
# A single shared code you distribute to sadhaks via WhatsApp / email.
# Rotate by changing this value + `docker compose restart backend`.
INVITE_CODE=REPLACE_ME_pick_something_memorable

# --- Rate + spend controls (RFC-016 §3) ------------------------------------
# Per-IP rate limit (requests per minute) and global daily cap on answered
# queries. The global cap fires BEFORE the Anthropic call, so overspend costs
# nothing beyond a 429.
RATE_LIMIT_PER_MIN=10
DAILY_ANSWER_CAP=200

# --- Where the bind-mounted corpus lives on the host ----------------------
# docker-compose reads this to mount `${DATA_ROOT}/04_processed` and
# `${DATA_ROOT}/01_canonical` into the container. On Lightsail this defaults
# to /home/ubuntu/data (see docker-compose.yml).
DATA_ROOT=/home/ubuntu/data
